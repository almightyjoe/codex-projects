<Window x:Class="ConnectionObserver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Connection Observer"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="960"
        Background="#F5F7FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Connection Observer" FontSize="28" FontWeight="SemiBold" Foreground="#162033" />
                <TextBlock x:Name="StatusText" Text="Live Windows network activity" Margin="0,4,0,0" Foreground="#526070" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="AutoRefreshCheckBox"
                          Margin="0,0,16,0"
                          VerticalAlignment="Center"
                          Checked="AutoRefreshCheckBox_Changed"
                          Unchecked="AutoRefreshCheckBox_Changed"
                          Content="Auto refresh" />
                <Button x:Name="RefreshButton"
                        Width="120"
                        Height="36"
                        Click="RefreshButton_Click"
                        Content="Refresh" />
            </StackPanel>
        </DockPanel>

        <UniformGrid Grid.Row="2" Columns="4">
            <Border Background="White" BorderBrush="#DCE2EA" BorderThickness="1" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Total" Foreground="#526070" />
                    <TextBlock x:Name="TotalConnectionsText" Text="0" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE2EA" BorderThickness="1" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="TCP" Foreground="#526070" />
                    <TextBlock x:Name="TcpConnectionsText" Text="0" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE2EA" BorderThickness="1" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="UDP" Foreground="#526070" />
                    <TextBlock x:Name="UdpConnectionsText" Text="0" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE2EA" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="Alerts" Foreground="#526070" />
                    <TextBlock x:Name="AlertCountText" Text="0" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <TabControl Grid.Row="4">
            <TabItem Header="Live">
                <DataGrid x:Name="ConnectionsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          Background="White"
                          BorderBrush="#DCE2EA"
                          BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="90" />
                        <DataGridTextColumn Header="Local" Binding="{Binding LocalEndpoint}" Width="*" />
                        <DataGridTextColumn Header="Remote" Binding="{Binding RemoteEndpoint}" Width="*" />
                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="140" />
                        <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="160" />
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="90" />
                        <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen}" Width="180" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="History">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Width="140" Height="32" Margin="0,0,0,12" HorizontalAlignment="Left" Click="ReloadHistoryButton_Click" Content="Reload History" />
                    <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Background="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="90" />
                            <DataGridTextColumn Header="Local" Binding="{Binding LocalEndpoint}" Width="*" />
                            <DataGridTextColumn Header="Remote" Binding="{Binding RemoteEndpoint}" Width="*" />
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="140" />
                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="160" />
                            <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen}" Width="180" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="DNS Notes">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DnsDomainTextBox" Grid.Column="0" Height="32" Margin="0,0,8,0" VerticalContentAlignment="Center" ToolTip="Domain" />
                        <TextBox x:Name="DnsIpTextBox" Grid.Column="1" Height="32" Margin="0,0,8,0" VerticalContentAlignment="Center" ToolTip="IP address" />
                        <TextBox x:Name="DnsNoteTextBox" Grid.Column="2" Height="32" Margin="0,0,8,0" VerticalContentAlignment="Center" ToolTip="Note" />
                        <Button Grid.Column="3" Height="32" Click="SaveDnsNoteButton_Click" Content="Save Note" />
                    </Grid>
                    <DataGrid x:Name="DnsGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Background="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="2*" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="*" />
                            <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="3*" />
                            <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen}" Width="180" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Alerts">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Width="130" Height="32" Margin="0,0,0,12" HorizontalAlignment="Left" Click="ReloadAlertsButton_Click" Content="Reload Alerts" />
                    <DataGrid x:Name="AlertsGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Background="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="110" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="3*" />
                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="160" />
                            <DataGridTextColumn Header="Remote" Binding="{Binding RemoteEndpoint}" Width="*" />
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt}" Width="180" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Rules">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="RuleTypeComboBox" Grid.Column="0" Height="32" Margin="0,0,8,0" />
                        <TextBox x:Name="RuleConditionTextBox" Grid.Column="1" Height="32" Margin="0,0,8,0" VerticalContentAlignment="Center" />
                        <ComboBox x:Name="RuleSeverityComboBox" Grid.Column="2" Height="32" Margin="0,0,8,0" />
                        <Button Grid.Column="3" Height="32" Click="AddRuleButton_Click" Content="Add Rule" />
                    </Grid>
                    <DataGrid x:Name="RulesGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Background="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="190" />
                            <DataGridTextColumn Header="Condition" Binding="{Binding Condition}" Width="*" />
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="120" />
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
